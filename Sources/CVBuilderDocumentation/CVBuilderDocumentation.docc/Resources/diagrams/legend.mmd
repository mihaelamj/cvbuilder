%% Color legend for every CVBuilder catalog diagram. Read this first.
%% The same classes color every other diagram. The first six are data-flow
%% roles; the last two are roadmap status. Vertical layout; invisible links
%% keep order without implying flow.
flowchart TD
    L1["Source of truth<br/>typed CV data or CVDocument JSON"]
    L2["Deterministic transform<br/>renderer or CLI step"]
    L3["Generated artifact<br/>Markdown or normalized JSON"]
    L4["Downstream consumer<br/>outside the CVBuilder boundary"]
    L5["Non-goal<br/>never generated by the core renderer"]
    L6["Research evidence or surviving rule"]
    L7["Roadmap phase shipped"]
    L8["Roadmap phase in progress"]

    L1 ~~~ L2 ~~~ L3 ~~~ L4 ~~~ L5 ~~~ L6 ~~~ L7 ~~~ L8

    classDef source fill:#d2e3fc,stroke:#1967d2,color:#111;
    classDef process fill:#feefc3,stroke:#e8710a,color:#111;
    classDef output fill:#ceead6,stroke:#137333,color:#111;
    classDef external fill:#cbf0f8,stroke:#007b83,color:#111;
    classDef excluded fill:#fad2cf,stroke:#c5221f,color:#111;
    classDef evidence fill:#e9d2fd,stroke:#8430ce,color:#111;
    classDef done fill:#e8eaed,stroke:#5f6368,color:#111;
    classDef active fill:#fef08a,stroke:#9a8400,color:#111;

    class L1 source;
    class L2 process;
    class L3 output;
    class L4 external;
    class L5 excluded;
    class L6 evidence;
    class L7 done;
    class L8 active;
